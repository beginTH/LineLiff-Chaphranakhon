    {
      "parameters": {
        "jsCode": "function parseJson(value, fallback) {\n  try { return value ? JSON.parse(value) : fallback; } catch { return fallback; }\n}\n\nconst order = $node['Build Order Row'].json;\nconst details = parseJson(order.Order_Details, {});\nconst deliveryAddress = parseJson(order.Delivery_Address, {});\nconst rows = $input.all().map(item => item.json);\nconst row = rows.find(r => String(r.LINE_UID || '').trim() === String(order.LINE_UID || '').trim()) || {};\n\nconst update = {\n  LINE_UID: order.LINE_UID,\n  Display_Name: row.Display_Name || details.displayName || '',\n  Branch_Name: row.Branch_Name || deliveryAddress.label || details.displayName || '',\n  Opening: row.Opening || '',\n  Tel: row.Tel || '',\n};\n\nfor (const num of [1, 2, 3, 4, 5]) {\n  update[`Address_${num}`] = row[`Address_${num}`] || '';\n  update[`Address_Label_${num}`] = row[`Address_Label_${num}`] || '';\n}\n\nconst newText = String(deliveryAddress.text || '').trim();\nconst newLabel = String(deliveryAddress.label || '').trim();\nconst existing = [1, 2, 3, 4, 5]\n  .map(num => String(update[`Address_${num}`] || '').trim())\n  .filter(Boolean);\n\nif (details.isNewAddress && newText && !existing.includes(newText)) {\n  const emptyNum = [1, 2, 3, 4, 5].find(num => !String(update[`Address_${num}`] || '').trim());\n  if (emptyNum) {\n    update[`Address_${emptyNum}`] = newText;\n    update[`Address_Label_${emptyNum}`] = newLabel || update.Branch_Name || `ที่อยู่ ${emptyNum}`;\n  }\n}\n\nreturn [{ json: update }];"
      },
