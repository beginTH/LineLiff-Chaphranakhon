      "parameters": {
        "jsCode": "function norm(value){return String(value||'').trim().toLowerCase();}\nfunction asBool(value){if(typeof value==='boolean')return value;return ['true','1','yes','y'].includes(norm(value));}\nfunction clean(value){return String(value??'').replace(/[\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F]/g,'').trim();}\nfunction parseJson(value){try{return value?JSON.parse(value):{};}catch{return {};}}\nconst source=$node['Build Payment Proof Update'].json;\nconst rows=$items('Read Orders For Payment Proof').map(i=>i.json);\nconst order=rows.find(r=>String(r.Order_ID||'')===String(source.orderId||''));\nconst delivery=parseJson(order?.Delivery_Address);\nconst branch=clean(delivery.label||delivery.branchName||order?.LINE_UID||'-');\nconst expected=Number(order?.Total_Amount||0), submitted=Number(source.amount||0), diff=submitted-expected;\nconst money=v=>Number(v||0).toLocaleString('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2});\nconst proof=clean(source.paymentProofUrl||'');\nconst orderId=clean(source.orderId||'');\nconst reviewUrl='https://liff.line.me/2010570929-BJxo68XQ?mode=payment&orderId='+encodeURIComponent(orderId);\nconst admins=$input.all().map(i=>i.json).filter(a=>String(a.LINE_UID||a.lineUid||'').trim()&&norm(a.Status)==='active'&&(asBool(a.Notify_Payment_Verification)||asBool(a.Notify_Payment_Submitted)));\nif(!admins.length) throw new Error('No active admin enabled for payment notification');\nconst text=['มีหลักฐานการชำระเงินใหม่รอตรวจสอบ','เลขที่: '+orderId,'สาขา: '+branch,'ยอดที่ต้องชำระ: ฿'+money(expected),'ยอดที่แจ้งโอน: ฿'+money(submitted),'ส่วนต่าง: ฿'+money(diff),'วันเวลาที่โอน: '+clean(source.transferAt||'-'),'หลักฐานการโอน: '+proof,'เปิดหน้าตรวจสอบ: '+reviewUrl].join(String.fromCharCode(10)).slice(0,1800);\nreturn admins.map(a=>({json:{to:String(a.LINE_UID||a.lineUid).trim(),adminId:a.Admin_ID||'',adminName:a.Display_Name||'',text}}));"
      }
